{
  "name": "feedback-analytics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "server:dev": "tsx src/server/express/index.ts",
    "dev:web": "npm run dev -w @feedback/web",
    "dev:api": "npm run dev -w @feedback/backend-gateway",
    "dev:all": "concurrently -n web,api -c green,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "build": "vite build",
    "build:web": "npm run build -w @feedback/web",
    "lint": "eslint .",
    "lint:web": "npm run lint -w @feedback/web",
    "lint:api": "npm run lint -w @feedback/backend-gateway",
    "preview": "vite preview",
    "test": "vitest",
    "test:web": "npm run test -w @feedback/web"
  },
  "dependencies": {
    "@google/genai": "^1.29.1",
    "@hookform/resolvers": "^5.2.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@tailwindcss/vite": "^4.1.11",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "path": "^0.12.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.61.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.7.1",
    "tailwindcss": "^4.1.11",
    "zod": "^4.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
