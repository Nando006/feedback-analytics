{
  "name": "feedback-analytics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:api": "npm run dev --prefix apps/backend-gateway",
    "dev:ia": "npm run dev --prefix services/ia-studio",
    "server:dev": "npm run dev:api",
    "server:ia-studio:dev": "npm run dev:ia",
    "dev:all": "echo \"Use dois terminais: npm run dev:web e npm run dev:api\"",
    "build": "npm run build --prefix apps/web",
    "build:web": "npm run build --prefix apps/web",
    "lint": "npm run lint:api && npm run lint:web && npm run lint:ia",
    "lint:web": "npm run lint --prefix apps/web",
    "lint:api": "npm run lint --prefix apps/backend-gateway",
    "lint:ia": "npm run lint --prefix services/ia-studio",
    "preview": "npm run preview --prefix apps/web",
    "test": "npm run test --prefix apps/web",
    "test:web": "npm run test --prefix apps/web"
  }
}
