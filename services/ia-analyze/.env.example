# Porta local do serviço ia-analyze.
PORT=4100 # Local

# Token interno opcional para proteger chamadas do API Gateway.
IA_ANALYZE_INTERNAL_TOKEN= # Local/Preview/Produção

# Chave da API Gemini usada pelo motor de análise.
GEMINI_API_KEY= # Local/Preview/Produção

# Máx. de chamadas simultâneas ao Gemini por requisição (evita rate limit 429).
# Comece baixo (3) — limites de RPM são por projeto. Default 3.
IA_GEMINI_CONCURRENCY=3 # Local/Preview/Produção
