{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,

    /* Bundler mode */
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "components/*": ["apps/web/components/*"],
      "pages/*": ["apps/web/pages/*"],
      "layouts/*": ["apps/web/layouts/*"],
      "lib/*": ["lib/*"],
      "src/*": ["apps/web/src/*"],
      "server/*": ["apps/backend-gateway/src/server/*"],
      "styles/*": ["apps/web/styles/*"]
    }
  },
  "include": [
    "apps/backend-gateway/src/server/**/*.ts",
    "apps/backend-gateway/src/server/**/*.d.ts",
    "lib/interfaces/**/*.ts",
    "lib/schemas/**/*.ts"
  ],
  "exclude": [
    "lib/utils/**",
    "lib/mock/**",
    "lib/**/tests/**",
    "apps/web/components/**",
    "apps/web/pages/**",
    "apps/web/styles/**"
  ]
}
