{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
  "module": "ESNext",
  "moduleResolution": "bundler",
    "skipLibCheck": true,

    /* Bundler mode */
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "components/*": ["components/*"],
      "pages/*": ["pages/*"],
      "layouts/*": ["layouts/*"],
      "lib/*": ["lib/*"],
      "src/*": ["src/*"],
      "server/*": ["src/server/*"]
    }
  },
  "include": [
    "src/server/**/*.ts",
    "src/server/**/*.d.ts",
    "lib/interfaces/**/*.ts",
    "lib/schemas/**/*.ts"
  ],
  "exclude": [
    "lib/utils/**",
    "lib/mock/**",
    "lib/**/tests/**",
    "components/**",
    "pages/**",
    "styles/**"
  ]
}
